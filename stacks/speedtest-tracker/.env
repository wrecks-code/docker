SPEEDTEST_HOST=speed.home.lan
SPEEDTEST_APP_KEY=base64:rT/ZxXg/Ph7+azX7V9H1GfxAjAZZpHjRLMu3dAWKWss=
# Zeitzone (wichtig für die Graphen)
TZ=Europe/Berlin

# Alle 4 Stunden zur vollen Stunde
SPEEDTEST_SCHEDULE="0 */6 * * *"

# Server-Auswahl
# Leer lassen für Auto-Select (nimmt meist den besten Ping)
# Falls er einen schlechten Server wählt, hier die ID eintragen (findest du im UI)
SPEEDTEST_SERVERS=

# Datenbank-Pflege (WICHTIG bei SQLite)
# Löscht Ergebnisse älter als 30 Tage, damit die DB nicht explodiert
PRUNE_RESULTS_OLDER_THAN=30

# UI Einstellungen
DISPLAY_TIMEZONE=Europe/Berlin
# Zeigt Ping/Jitter/Upload/Download in den Charts
CHART_DATETIME_FORMAT="d.m.Y H:i"

# Optional: EULA für Ookla Binary explizit akzeptieren (vermeidet Log-Fehler)
SPEEDTEST_EULA_ACCEPTED=true